#include <stdio.h>

int main() {
    float hours, total = 0, avg;
    int below2 = 0;

    for (int i = 1; i <= 7; i++) {
        printf("Day %d hours: ", i);
        scanf("%f", &hours);

        total += hours;

        if (hours < 2)
            below2++;
    }

    avg = total / 7;

    printf("Total hours: %.2f\n", total);
    printf("Average hours: %.2f\n", avg);
    printf("Days below 2 hours: %d", below2);

    return 0;
}

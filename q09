#include <stdio.h>

int main() {
    int num, digit, sum = 0, odd = 0;

    printf("Enter number: ");
    scanf("%d", &num);

    while (num > 0) {
        digit = num % 10;
        sum += digit;

        if (digit % 2 != 0)
            odd++;

        num /= 10;
    }

    printf("Sum of digits: %d\n", sum);
    printf("Odd digits count: %d", odd);

    return 0;
}

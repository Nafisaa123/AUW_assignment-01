#include <stdio.h>

int main() {
    float price, total = 0, discount, final;

    while (1) {
        printf("Enter price (0 to stop): ");
        scanf("%f", &price);

        if (price == 0)
            break;

        total += price;
    }

    if (total > 2000)
        discount = total * 0.15;
    else
        discount = total * 0.05;

    final = total - discount;

    printf("Total: %.2f\n", total);
    printf("Discount: %.2f\n", discount);
    printf("Final bill: %.2f", final);

    return 0;
}
